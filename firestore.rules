rules_version = '2';

/**
==========================================================
CGTIA CMS & Client — Unified Firestore Security Rules
==========================================================
Merged configuration supporting both the internal
staff backoffice dashboard and public-facing web intake.
Supports single database constraint on the free Spark plan.
==========================================================
*/

service cloud.firestore {
match /databases/{database}/documents {

// =======================================================
// 1. CORE UNIFIED AUTHENTICATION & ROLE HELPERS
// =======================================================
function isSignedIn() {
return request.auth != null;
}

function myProfile() {
return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
}

function myRole() {
return isSignedIn() ? myProfile().role : null;
}

function isActive() {
return isSignedIn() && myProfile().active != false;
}

function isAdmin() {
return (isSignedIn() && isActive() && (myRole() == 'super-admin' || myRole() == 'admin'))
|| (isSignedIn() && request.auth.token.role == 'admin');
}

function hasRole(roles) {
return isSignedIn() && isActive() && myRole() in roles;
}

function isOwner(uid) {
return isSignedIn() && request.auth.uid == uid;
}

function hasOnlyKeys(allowedKeys) {
return request.resource.data.keys().hasOnly(allowedKeys);
}

/* ---------------- users (Staff & Student Accounts) ---------------- */
match /users/{uid} {
allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
allow create: if false || isAdmin();
allow delete: if isAdmin();
allow update: if isAdmin() ||
(isSignedIn() && request.auth.uid == uid &&
request.resource.data.role == resource.data.role &&
request.resource.data.active == resource.data.active) ||
(isOwner(uid) && hasOnlyKeys(['mustChangePassword']) && request.resource.data.mustChangePassword == false);
}

// =======================================================
// 2. BACKOFFICE & CORE INSTITUTION COLLECTIONS
// =======================================================

/* ---------------- students ---------------- */
match /students/{studentId} {
allow read: if hasRole(['registrar', 'training-officer', 'instructor']) || isAdmin();
allow create, update: if hasRole(['registrar', 'training-officer']) || isAdmin();
allow delete: if isAdmin();
}

/* ---------------- staff (institution employees) ---------------- */
match /staff/{staffId} {
allow read: if hasRole(['registrar', 'training-officer']) || isAdmin();
allow create, update: if isAdmin();
allow delete: if isAdmin();
}

/* ---------------- programs Reference Data ---------------- */
match /programs/{programKey} {
allow read: if true;
allow write: if isAdmin();
}

/* ---------------- courses ---------------- */
match /courses/{courseId} {
allow read: if isSignedIn();
allow create, update: if hasRole(['training-officer', 'instructor']) || isAdmin();
allow delete: if isAdmin();
}

/* ---------------- notifications ---------------- */
match /notifications/{notifId} {
allow read, update: if isSignedIn() && resource.data.uid == request.auth.uid;
allow create, delete: if isAdmin();
}

// =======================================================
// 3. PUBLIC FRONTEND FORM INGEST & CLIENT COLLECTIONS
// =======================================================

/* ---------------- certificates ---------------- */
match /certificates/{certId} {
allow read: if true; // Public verification
allow create, update: if hasRole(['registrar', 'training-officer']) || isAdmin();
allow delete: if isAdmin();
}

/* ---------------- licences ---------------- */
match /licences/{licenceId} {
allow read: if true;
allow create, update: if hasRole(['licensing-officer']) || isAdmin();
allow delete: if isAdmin();
}

/* =====================================================
applications – secure public intake with limited updates
===================================================== */
match /applications/{appId} {
// Create: only when document ID equals email, all required fields present,
// and exactly those fields (no extras). Status/payment must be initial.
allow create: if
appId == request.resource.data.email.lower()
&& !exists(/databases/$(database)/documents/applications/$(appId))
&& request.resource.data.keys().hasOnly([
'fullName','phone','email','program','startDate','message',
'status','paymentStatus','paymentPlan','installmentsTotal','installmentsPaid',
'createdAt','updatedAt'
])
&& request.resource.data.status == "pending"
&& request.resource.data.paymentStatus == "unpaid"
&& request.resource.data.paymentPlan == "full"
&& request.resource.data.installmentsTotal == 1
&& request.resource.data.installmentsPaid == 0;

// Read: admin or the applicant themselves (if signed in with the same email)
allow read: if isAdmin()
|| (isSignedIn() && request.auth.token.email == resource.data.email);

// Update: only admin OR (unauthenticated applicant with matching email)
// and only while still unpaid, and only fields: paymentPlan, installmentsTotal, updatedAt
allow update: if
isAdmin()
|| (
!isSignedIn()
&& appId == request.resource.data.email
&& resource.data.email == request.resource.data.email
&& resource.data.paymentStatus == "unpaid"
&& resource.data.installmentsPaid == 0
&& request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentPlan', 'installmentsTotal', 'updatedAt'])
&& request.resource.data.paymentPlan in ['full', 'installment']
&& request.resource.data.installmentsTotal in [1, 3]
);

allow delete: if isAdmin();
}

/* ---------------- licensingApplications ---------------- */
match /licensingApplications/{reqId} {
allow create: if request.resource.data.keys().hasAll(
['fullName', 'email', 'phone', 'status', 'paymentStatus', 'createdAt']
)
&& request.resource.data.status == 'pending'
&& request.resource.data.paymentStatus == 'unpaid';
allow read, update, delete: if isAdmin();
}

/* ---------------- customRequests ---------------- */
match /customRequests/{reqId} {
allow create: if request.resource.data.keys().hasAll(
['applicantType', 'name', 'email', 'phone', 'status', 'createdAt']
)
&& request.resource.data.applicantType in ['individual', 'school', 'organization']
&& request.resource.data.status == 'new';
allow read, update, delete: if isAdmin();
}

/* ---------------- contactMessages ---------------- */
match /contactMessages/{msgId} {
allow create: if request.resource.data.keys().hasAll(
['message', 'preferredContactMethod', 'contactValue', 'status', 'createdAt']
)
&& request.resource.data.preferredContactMethod in ['email', 'whatsapp']
&& request.resource.data.status == 'new';
allow read, update, delete: if isAdmin();
}

// =======================================================
// 4. GLOBAL SECURITY BACKSTOP
// =======================================================
match /{document=**} {
allow read, write: if false;
}
}
}